# Required
OPENAI_API_KEY=your-openai-api-key

# Retrieval providers
TAVILY_API_KEY=your-tavily-api-key       # https://tavily.com — free tier, 1000 searches/month
NEWSDATA_API_KEY=your-newsdata-api-key   # https://newsdata.io — free tier, 200 credits/day

# Optional / defaults
RATE_LIMIT_PER_MINUTE=10

# Environment
ENV=development
